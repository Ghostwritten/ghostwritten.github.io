<h3 id="15-е≠Чзђ¶дЄ≤ињРзЃЧзђ¶">1.5. е≠Чзђ¶дЄ≤ињРзЃЧзђ¶</h3>

<p>дЄЛи°®еИЧеЗЇдЇЖеЄЄзФ®зЪДе≠Чзђ¶дЄ≤ињРзЃЧзђ¶пЉМеБЗеЃЪеПШйЗП a дЄЇ вАЬabcвАЭпЉМеПШйЗП b дЄЇ вАЬefgвАЭпЉЪ</p>

<p>иѓіжШО:</p>

<ul>
  <li>=	ж£АжµЛдЄ§дЄ™е≠Чзђ¶дЄ≤жШѓеР¶зЫЄз≠ЙпЉМзЫЄз≠ЙињФеЫЮ trueгАВ	[ $a = $b ] ињФеЫЮ falseгАВ</li>
  <li>!=	ж£АжµЛдЄ§дЄ™е≠Чзђ¶дЄ≤жШѓеР¶зЫЄз≠ЙпЉМдЄНзЫЄз≠ЙињФеЫЮ trueгАВ	[ $a != $b ] ињФеЫЮ trueгАВ</li>
  <li>-z	ж£АжµЛе≠Чзђ¶дЄ≤йХњеЇ¶жШѓеР¶дЄЇ0пЉМдЄЇ0ињФеЫЮ trueгАВ	[ -z $a ] ињФеЫЮ falseгАВ</li>
  <li>-n	ж£АжµЛе≠Чзђ¶дЄ≤йХњеЇ¶жШѓеР¶дЄЇ0пЉМдЄНдЄЇ0ињФеЫЮ trueгАВ	[ -n $a ] ињФеЫЮ trueгАВ</li>
  <li>str	ж£АжµЛе≠Чзђ¶дЄ≤жШѓеР¶дЄЇз©ЇпЉМдЄНдЄЇз©ЇињФеЫЮ trueгАВ	[ $a ] ињФеЫЮ trueгАВ</li>
</ul>

<p>еЃЮдЊЛ</p>

<div class="language-plaintext highlighter-rouge"><div class="highlight"><pre class="highlight"><code>#!/bin/bash
 
a="abc"
b="efg"
 
if [ $a = $b ]
then
   echo "$a = $b : a з≠ЙдЇО b"
else
   echo "$a = $b: a дЄНз≠ЙдЇО b"
fi
if [ $a != $b ]
then
   echo "$a != $b : a дЄНз≠ЙдЇО b"
else
   echo "$a != $b: a з≠ЙдЇО b"
fi
if [ -z $a ]
then
   echo "-z $a : е≠Чзђ¶дЄ≤йХњеЇ¶дЄЇ 0"
else
   echo "-z $a : е≠Чзђ¶дЄ≤йХњеЇ¶дЄНдЄЇ 0"
fi
if [ -n $a ]
then
   echo "-n $a : е≠Чзђ¶дЄ≤йХњеЇ¶дЄНдЄЇ 0"
else
   echo "-n $a : е≠Чзђ¶дЄ≤йХњеЇ¶дЄЇ 0"
fi
if [ $a ]
then
   echo "$a : е≠Чзђ¶дЄ≤дЄНдЄЇз©Ї"
else
   echo "$a : е≠Чзђ¶дЄ≤дЄЇз©Ї"
fi
</code></pre></div></div>

<p>жЙІи°МиДЪжЬђпЉМиЊУеЗЇзїУжЮЬе¶ВдЄЛжЙАз§ЇпЉЪ</p>

